{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Codex Thread Kanban",
  "version": "0.1.0",
  "identifier": "local.codex.thread-kanban",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../src-ui/dist"
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "app": {
    "windows": [
      {
        "title": "Codex Thread Kanban",
        "width": 1320,
        "height": 820,
        "minWidth": 1080,
        "minHeight": 680
      }
    ]
  }
}
